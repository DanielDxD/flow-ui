{
    "name": "@danielgl/flow-ui",
    "version": "1.0.3",
    "description": "A lightweight, declarative, SwiftUI-inspired UI framework for the web.",
    "type": "module",
    "main": "./dist/flow-ui.umd.js",
    "module": "./dist/flow-ui.es.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/flow-ui.es.js",
            "require": "./dist/flow-ui.umd.js"
        }
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "lint": "eslint src/",
        "test": "vitest run",
        "prepare": "husky"
    },
    "keywords": [
        "web",
        "framework",
        "reactive",
        "front-end",
        "typescript",
        "swift",
        "UI"
    ],
    "author": "Daniel Lopes",
    "license": "MIT",
    "packageManager": "pnpm@10.30.2",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@types/jsdom": "^28.0.0",
        "@types/node": "^25.3.1",
        "eslint": "^10.0.2",
        "globals": "^17.3.0",
        "husky": "^9.1.7",
        "jsdom": "^28.1.0",
        "lint-staged": "^16.3.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vite": "^7.3.1",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.0.18"
    },
    "dependencies": {},
    "displayName": "Flow UI",
    "lint-staged": {
        "src/**/*.{ts,tsx}": [
            "eslint --fix",
            "vitest related --run"
        ]
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/DanielDxD/flow-ui"
    }
}
